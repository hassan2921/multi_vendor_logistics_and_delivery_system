# Copy this file to .env (same directory) and fill in your own values.
# All values below are PLACEHOLDERS — replace with your own free-tier
# Supabase/Stripe projects and a Google Maps API key.
#
# .env is bundled as a Flutter asset (see pubspec.yaml) and read at startup
# by lib/core/config/env.dart via flutter_dotenv. It is gitignored.

SUPABASE_URL=PLACEHOLDER_https://your-project.supabase.co
SUPABASE_ANON_KEY=PLACEHOLDER_SUPABASE_ANON_KEY

# Backend API base URL (the Express server from /backend)
API_BASE_URL=http://localhost:3000

# Stripe publishable (test mode) key — safe to ship to the client.
STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_pk_test_xxxxxxxxxxxx

# Only needed to render Google Maps tiles; app logic runs without it.
GOOGLE_MAPS_API_KEY=PLACEHOLDER_GOOGLE_MAPS_API_KEY
