# Copy this file to .env and fill in your own values.
# All values below are PLACEHOLDERS — replace with your own free-tier Supabase/Stripe projects.

PORT=3000
NODE_ENV=development

# Supabase project settings (Project Settings > API in the Supabase dashboard)
SUPABASE_URL=PLACEHOLDER_https://your-project.supabase.co
SUPABASE_ANON_KEY=PLACEHOLDER_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SUPABASE_SERVICE_ROLE_KEY

# Stripe (use TEST mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=PLACEHOLDER_sk_test_xxxxxxxxxxxx
# From `stripe listen --forward-to localhost:3000/payments/webhook` output, or the Stripe dashboard webhook config
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_whsec_xxxxxxxxxxxx

# ── Everything below is OPTIONAL (sensible defaults apply) ──────────────────

# Pricing engine (cents)
#DELIVERY_BASE_FEE_CENTS=199
#DELIVERY_PER_KM_CENTS=60
#DELIVERY_FEE_CAP_CENTS=999

# Marketplace economics
#PLATFORM_FEE_PERCENT=15
#COURIER_DELIVERY_FEE_SHARE_PERCENT=80

# Stripe Connect onboarding redirect URLs (shown after a vendor finishes/abandons onboarding)
#CONNECT_RETURN_URL=https://example.com/connect/return
#CONNECT_REFRESH_URL=https://example.com/connect/refresh

# Firebase Cloud Messaging (from a Firebase service-account JSON). If unset,
# push is skipped and in-app notifications still work via Supabase Realtime.
#FCM_PROJECT_ID=your-firebase-project
#FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
#FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
